{
    "manifest_version": 3,
    "name": "Skipr",
    "version": "1.0",
    "description": "Auto skip intro on Netflix",


    "icons": {
  "16": "assets/16.png",
  "48": "assets/48.png",
  "128": "assets/128.png"
  },
  
    "permissions": ["storage"],
  
    "host_permissions": [
      "*://*.netflix.com/*"
    ],
  
    "content_scripts": [
      {
        "matches": ["*://*.netflix.com/*"],
        "js": ["content/content.js"]
      }
    ],
    "action": {
  "default_popup": "popup/popup.html"
}
}
  